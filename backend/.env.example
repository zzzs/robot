# 阿里云百炼
DASHSCOPE_API_KEY=your-dashscope-key
DASHSCOPE_BASE_URL=https://ai-platform.cai-inc.com/api/biz-ai/ai-model/api/11/apps/anthropic
DASHSCOPE_MODEL=glm-5.2

# 股票分析 (@pidanmoe/mcp-stock)
# TUSHARE_TOKEN 来自 https://tushare.pro,缺失时股票功能会优雅降级为 "No data available for analysis"
TUSHARE_TOKEN=
MCP_STOCK_COMMAND=npx
MCP_STOCK_ARGS=-y,@pidanmoe/mcp-stock
STOCK_MIN_BARS=60
STOCK_MAX_RETRIES=2
STOCK_RETRY_BACKOFF_MS=500

# LangSmith 可观测性 (可选,不填则关闭)
# 注册账号 + 拿 key: https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=robot
LANGSMITH_ENDPOINT=

# Orchestrator 选择 (可选,默认 manual)
#   manual     = 手写 ChatOrchestrator(原有 ReAct 实现)
#   langgraph  = LangGraph StateGraph 版本(学习/对比用)
#   supervisor = 多 agent (supervisor + researcher + summarizer) 学习用
ORCHESTRATOR=manual

# News RAG (可选,不填则用内置 fixture 演示)
# 默认 fixture:sample = 20 篇 A 股示例新闻(离线 demo,确保能跑通)
# 想换真数据源时(逗号分隔配置多个,自动 fallback):
#   fixture:sample                                内置示例(默认,离线)
#   https://rsshub.app/cls/telegraph              财联社(需 RSSHub 可达)
#   https://rsshub.app/wallstreetcn/news/global   华尔街见闻
#   http://localhost:1200/cls/telegraph           自部署 RSSHub
NEWS_RSS_URLS=fixture:sample
NEWS_INGEST_COUNT=50
NEWS_TOP_K=5
NEWS_EMBEDDING_BATCH_SIZE=10
NEWS_EMBEDDING_BATCH_DELAY_MS=200
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
DASHSCOPE_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# GLM Embedding(智谱 AI 官方,embedding-3 用于 RAG 向量化)
# 从 https://open.bigmodel.cn/ 注册 → 控制台 → API Keys 获取
# 格式: id.secret
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
