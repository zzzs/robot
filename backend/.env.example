# 阿里云百炼
DASHSCOPE_API_KEY=your-dashscope-key
DASHSCOPE_BASE_URL=https://ai-platform.cai-inc.com/api/biz-ai/ai-model/api/11/apps/anthropic
DASHSCOPE_MODEL=glm-5.2

# 股票分析 (@pidanmoe/mcp-stock)
# TUSHARE_TOKEN 来自 https://tushare.pro,缺失时股票功能会优雅降级为 "No data available for analysis"
TUSHARE_TOKEN=
MCP_STOCK_COMMAND=npx
MCP_STOCK_ARGS=-y,@pidanmoe/mcp-stock
STOCK_MIN_BARS=60
STOCK_MAX_RETRIES=2
STOCK_RETRY_BACKOFF_MS=500

# LangSmith 可观测性 (可选,不填则关闭)
# 注册账号 + 拿 key: https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=robot
LANGSMITH_ENDPOINT=

# Orchestrator 选择 (可选,默认 manual)
#   manual    = 手写 ChatOrchestrator(原有 ReAct 实现)
#   langgraph = LangGraph StateGraph 版本(学习/对比用)
ORCHESTRATOR=manual
